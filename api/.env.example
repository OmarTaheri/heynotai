PORT=8787
POCKETBASE_URL=http://127.0.0.1:8090
CORS_ORIGINS=http://localhost:3000,chrome-extension://*

# ── Stripe ────────────────────────────────────────────────────────
# Server-side key. Use a restricted (rk_test_…) or secret (sk_test_…)
# test-mode key from Stripe → Developers → API keys.
STRIPE_SECRET_KEY=

# From `stripe listen --forward-to localhost:8787/billing/webhook`.
# Used to verify webhook signatures.
STRIPE_WEBHOOK_SECRET=

# Per-plan recurring price IDs. Create three Products (Verify, Certify,
# Team) in Stripe Dashboard, each with a Monthly + Yearly Price, then
# paste the price IDs here.
STRIPE_PRICE_VERIFY_MONTHLY=
STRIPE_PRICE_VERIFY_YEARLY=
STRIPE_PRICE_CERTIFY_MONTHLY=
STRIPE_PRICE_CERTIFY_YEARLY=
STRIPE_PRICE_TEAM_MONTHLY=
STRIPE_PRICE_TEAM_YEARLY=

# PocketBase superuser used by the webhook handler to write invoice
# rows + sync subscription state. The webhook bypasses per-user RLS.
PB_ADMIN_EMAIL=admin@aui.ma
PB_ADMIN_PASSWORD=adminadmin

# ── Modulate Velma (audio deepfake) ───────────────────────────────
# The API key itself lives in PocketBase service_secrets.velmaApiKey
# (paste it in PB admin). These two only need to be set if Modulate
# changes the endpoint URL/path after this code was written.
# VELMA_BASE_URL=https://modulate-developer-apis.com
# VELMA_DETECT_PATH=/api/velma-2-synthetic-voice-detection-batch
