# Public (exposed to the browser) — must start with NEXT_PUBLIC_
NEXT_PUBLIC_POCKETBASE_URL=http://127.0.0.1:8090
NEXT_PUBLIC_API_URL=http://localhost:8787
# NEXT_PUBLIC_APP_URL=https://heynotai.com

# Stripe publishable key (safe to expose). Pair with STRIPE_SECRET_KEY
# in api/.env. Get both from https://dashboard.stripe.com/test/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Server-only — never prefixed with NEXT_PUBLIC_
# DATABASE_URL=postgres://user:pass@host:5432/heynotai
# AUTH_SECRET=change-me
# DETECT_API_KEY=
